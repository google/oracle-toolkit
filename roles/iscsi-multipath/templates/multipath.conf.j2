defaults {
    user_friendly_names yes
    find_multipaths     yes
}

devices {
    device {
        vendor               "NETAPP"
        product              "LUN"
        path_grouping_policy "group_by_prio"
        prio                 "ontap"
        path_checker         tur
        path_selector        "service-time 0"
        hardware_handler     "0 alua"
        failback             immediate
        rr_weight            uniform
        no_path_retry        30
        features             "0"
    }
}
{% set _aliases = iscsi_multipath_aliases_effective | default(iscsi_multipath_aliases) | default([]) %}
{% if _aliases | length > 0 %}

multipaths {
{% for m in _aliases %}
    multipath {
        wwid  "{{ m.wwid }}"
        alias {{ m.alias }}
    }
{% endfor %}
}
{% endif %}
